# Path to your Claude CLI config directory (contains OAuth credentials)
# Windows: C:\Users\YourName\.claude
# Mac/Linux: /home/yourname/.claude
CLAUDE_CONFIG_PATH=C:\Users\YourName\.claude

# Directory to mount as the agent workspace
WORKSPACE_PATH=./workspace

# API key required on all requests (X-API-Key header or Authorization: Bearer <key>)
# Leave blank to disable auth (dev/local use only)
API_KEY=your-secret-key-here
